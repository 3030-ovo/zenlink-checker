<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ZenLink タグ確認ツール</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#fff;--bg2:#f8f8f6;--bg3:#f1f0ec;
  --text:#1a1a18;--text2:#6b6b67;--text3:#9b9b97;
  --border:rgba(0,0,0,0.12);--border2:rgba(0,0,0,0.22);
  --info-bg:#e6f1fb;--info-text:#185fa5;--info-border:#b5d4f4;
  --ok-bg:#eaf3de;--ok-text:#3b6d11;
  --ng-bg:#fcebeb;--ng-text:#a32d2d;
  --warn-bg:#faeeda;--warn-text:#854f0b;
  --radius:8px;--radius-lg:12px;
}
body{font-family:-apple-system,BlinkMacSystemFont,'Hiragino Kaku Gothic ProN','Yu Gothic',sans-serif;background:var(--bg3);color:var(--text);min-height:100vh;font-size:15px}
.page{max-width:720px;margin:0 auto;padding:48px 20px 80px}
h1{font-size:20px;font-weight:500;margin-bottom:6px;display:flex;align-items:center;gap:8px}
.sub{font-size:13px;color:var(--text2);margin-bottom:32px}
.input-area{background:var(--bg);border:0.5px solid var(--border);border-radius:var(--radius-lg);padding:24px}
.input-row{display:flex;gap:10px}
.input-row input{flex:1;height:44px;border:0.5px solid var(--border2);border-radius:var(--radius);padding:0 14px;font-size:15px;background:var(--bg);color:var(--text);outline:none}
.input-row input:focus{border-color:var(--info-text);box-shadow:0 0 0 3px rgba(24,95,165,.08)}
.btn-check{height:44px;border:none;border-radius:var(--radius);background:var(--info-text);color:#fff;font-size:14px;font-weight:500;cursor:pointer;display:inline-flex;align-items:center;gap:8px;padding:0 22px;white-space:nowrap;transition:opacity .15s}
.btn-check:hover{opacity:.88}
.btn-check:disabled{opacity:.4;cursor:not-allowed}
.results{margin-top:20px;display:flex;flex-direction:column;gap:12px}
.result-card{background:var(--bg);border:0.5px solid var(--border);border-radius:var(--radius-lg);overflow:hidden}
.rh{display:flex;align-items:flex-start;gap:10px;padding:16px 20px 14px}
.badge{flex-shrink:0;font-size:11px;font-weight:600;padding:4px 12px;border-radius:20px;margin-top:2px;letter-spacing:.02em}
.badge-ok{background:var(--ok-bg);color:var(--ok-text)}
.badge-ng{background:var(--ng-bg);color:var(--ng-text)}
.badge-warn{background:var(--warn-bg);color:var(--warn-text)}
.badge-loading{background:var(--bg2);color:var(--text2)}
.rurl{font-size:14px;font-weight:500;flex:1;word-break:break-all;padding-top:2px}
.rurl a{color:var(--info-text);text-decoration:none}
.rurl a:hover{text-decoration:underline}
.rb{border-top:0.5px solid var(--border);padding:14px 20px}
.tabs{display:flex;border-bottom:0.5px solid var(--border);margin-bottom:14px}
.tab{font-size:12px;padding:7px 14px;cursor:pointer;color:var(--text2);border-bottom:2px solid transparent;background:none;border-top:none;border-left:none;border-right:none;border-radius:0;height:auto}
.tab:hover{color:var(--text)}
.tab.active{color:var(--info-text);border-bottom-color:var(--info-text);font-weight:500}
.tab-pane{display:none}.tab-pane.active{display:block}
.issue-list{list-style:none;font-size:13px;color:var(--text2);line-height:1.9}
.issue-list li{display:flex;gap:7px}
.issue-list li::before{content:"→";color:var(--text3);flex-shrink:0}
.plat{display:inline-flex;align-items:center;gap:5px;font-size:11px;background:var(--bg2);border:0.5px solid var(--border);border-radius:var(--radius);padding:4px 10px;margin-top:10px}
.plat a{color:var(--info-text);text-decoration:none}
.plat a:hover{text-decoration:underline}
.ss-wrap{background:var(--bg2);border:0.5px solid var(--border);border-radius:var(--radius);min-height:80px;display:flex;align-items:center;justify-content:center;font-size:13px;color:var(--text3);position:relative;overflow:hidden}
.ss-wrap img{width:100%;display:block}
.ss-badge{position:absolute;top:8px;right:8px;background:rgba(0,0,0,.5);color:#fff;font-size:10px;padding:3px 8px;border-radius:4px}
.ss-note{font-size:11px;color:var(--text3);margin-top:6px;line-height:1.6}
.ss-note a{color:var(--info-text)}
</style>
</head>
<body>
<div class="page">
  <h1><i class="fa-solid fa-tag"></i> ZenLink タグ確認ツール</h1>
  <p class="sub">URLを入力してZenLinkスクリプトの挿入状況を確認できます</p>

  <div class="input-area">
    <div class="input-row">
      <input type="text" id="urlInput" placeholder="https://example.com" />
      <button class="btn-check" id="checkBtn" onclick="runCheck()">
        <i class="fa-solid fa-magnifying-glass"></i> 確認する
      </button>
    </div>
  </div>

  <div class="results" id="results"></div>
</div>

<script>
const TARGET_SCRIPT = 'https://zen.one/analytics.js';
const SS_TOKEN = 'EHT2X68-DG5M6MX-GDWFYBJ-S9PNSC5';

const PROXIES = [
  url => `https://api.allorigins.win/get?url=${encodeURIComponent(url)}`,
  url => `https://api.codetabs.com/v1/proxy?quest=${encodeURIComponent(url)}`,
  url => `https://corsproxy.io/?${encodeURIComponent(url)}`,
];

const PLATFORMS = {
  shopify:    {name:'Shopify',         guide:'https://support.zen.one/zenlink-guide/tag/shopify'},
  base:       {name:'BASE',            guide:'https://support.zen.one/zenlink-guide/tag/base'},
  ecforce:    {name:'ecforce',         guide:'https://support.zen.one/zenlink-guide/tag/ecforce'},
  ochanoko:   {name:'おちゃのこネット', guide:'https://support.zen.one/zenlink-guide/tag/ochanoko'},
  makeshop:   {name:'Makeshop',        guide:'https://support.zen.one/zenlink-guide/tag/makeshop'},
  futureshop: {name:'futureshop',      guide:'https://support.zen.one/zenlink-guide/tag/futureshop'},
  colorme:    {name:'ColorMe',         guide:'https://support.zen.one/zenlink-guide/tag/colorme'},
  square:     {name:'Square',          guide:'https://support.zen.one/zenlink-guide/tag/square'},
  wix:        {name:'WIX',             guide:'https://support.zen.one/zenlink-guide/tag/wix'},
  eccube:     {name:'EC-CUBE',         guide:'https://support.zen.one/zenlink-guide/tag/ec-cube'},
  estore:     {name:'Eストアー',       guide:'https://support.zen.one/zenlink-guide/tag/estore'},
  wordpress:  {name:'WordPress',       guide:'https://support.zen.one/zenlink-guide/tag/wordpress'},
  aiship:     {name:'aiship',          guide:'https://support.zen.one/zenlink-guide/tag/aiship'},
};

async function fetchHtml(url) {
  for (const proxyFn of PROXIES) {
    try {
      const proxyUrl = proxyFn(url);
      console.log('[fetch] trying:', proxyUrl);
      const resp = await fetch(proxyUrl, {signal: AbortSignal.timeout(10000)});
      console.log('[fetch] status:', resp.status, resp.statusText);
      if (!resp.ok) { console.log('[fetch] not ok, skip'); continue; }
      const ct = resp.headers.get('content-type') || '';
      console.log('[fetch] content-type:', ct);
      if (ct.includes('application/json')) {
        const json = await resp.json();
        const html = json.contents || '';
        console.log('[fetch] json html length:', html.length, '| has zen.one:', html.includes('zen.one'));
        if (html.length > 100) return html;
      } else {
        const html = await resp.text();
        console.log('[fetch] text html length:', html.length, '| has zen.one:', html.includes('zen.one'));
        if (html.length > 100) return html;
      }
    } catch(e) { console.log('[fetch] error:', e.message); continue; }
  }
  throw new Error('全てのプロキシで取得に失敗しました');
}

function detectPlatform(html) {
  const h = (html || '').toLowerCase();
  if (h.includes('cdn.shopify.com') || h.includes('myshopify.com')) return 'shopify';
  if (h.includes('shop-pro.jp') || h.includes('shop-pro.net') || h.includes('colormeapp') || h.includes('gmo-shop')) return 'colorme';
  if (h.includes('base.shop') || h.includes('base-cdn.jp') || h.includes('thebase.in')) return 'base';
  if (h.includes('ecforce')) return 'ecforce';
  if (h.includes('ochanoko')) return 'ochanoko';
  if (h.includes('makeshop')) return 'makeshop';
  if (h.includes('futureshop')) return 'futureshop';
  if (h.includes('squarespace.com')) return 'square';
  if (h.includes('wix.com') || h.includes('wixsite.com') || h.includes('wix-bolt')) return 'wix';
  if (h.includes('eccube') || h.includes('ec-cube')) return 'eccube';
  if (h.includes('aiship')) return 'aiship';
  if (h.includes('wp-content') || h.includes('wp-includes')) return 'wordpress';
  return null;
}

function analyzeTag(html) {
  const issues = [];
  let status = 'ok';
  const h = html || '';

  // 1. そもそも zen.one/analytics への参照があるか
  console.log('[analyze] html length:', h.length, '| has zen.one:', h.toLowerCase().includes('zen.one/analytics'));
  console.log('[analyze] html snippet (head area):', h.substring(0, 500));
  if (!h.toLowerCase().includes('zen.one/analytics')) {
    issues.push('スクリプトタグが見つかりません（未挿入）');
    return {status: 'ng', issues};
  }

  // 2. ColorMe等の動的挿入パターンを確認
  //    例: {"src":"https://zen.one/analytics.js?tokenxxx"}
  const dynamicPattern = /["'](https:\/\/zen\.one\/analytics\.js[^"']*)['"]/gi;
  const dynamicMatches = [...h.matchAll(dynamicPattern)].map(m => m[1]);
  const isDynamic = dynamicMatches.length > 0;

  // 3. 通常の <script src="...analytics.js..."> タグを確認
  const scriptTags = [...h.matchAll(/<script[^>]*>/gi)].map(m => m[0]);
  const targetTags = scriptTags.filter(s => s.includes('analytics.js'));

  if (isDynamic && targetTags.length === 0) {
    // ColorMe方式：JS内で動的生成 → 正常
    issues.push('正常: アプリ連携による動的挿入が確認できました');
    return {status: 'ok', issues};
  }

  if (!isDynamic && targetTags.length === 0) {
    issues.push('zen.one/analytics.js への参照はありますが、認識できない形式で挿入されています');
    status = 'warn';
  }

  // 4. 通常タグの詳細チェック
  targetTags.forEach(tag => {
    if (!tag.includes('async')) {
      issues.push('async 属性がありません（ページ表示速度に影響する可能性があります）');
      if (status === 'ok') status = 'warn';
    }
    const m = tag.match(/src\s*=\s*["']([^"']+)["']/i);
    if (m) {
      const src = m[1];
      // クエリパラメータ付きも許容
      if (!src.startsWith('https://zen.one/analytics.js')) {
        issues.push(`src URL が正しくありません: ${src}`);
        if (status === 'ok') status = 'warn';
      }
    }
  });

  // 5. 挿入位置チェック（<head> 内かどうか）
  const headMatch = h.match(/<head[\s\S]*?<\/head>/i);
  if (headMatch) {
    const hd = headMatch[0];
    if (!hd.includes('analytics.js')) {
      issues.push('スクリプトが &lt;head&gt; 内ではなく body 等に挿入されています（プラットフォームによっては正常な場合があります）');
      if (status === 'ok') status = 'warn';
    } else if (hd.lastIndexOf('</head>') - hd.lastIndexOf('analytics.js') > 2000) {
      issues.push('スクリプトが &lt;head&gt; の上部に挿入されています（推奨: &lt;/head&gt; の直前）');
      if (status === 'ok') status = 'warn';
    }
  }

  if (status === 'ok') issues.push('正常: 推奨位置にスクリプトタグが確認できました');
  return {status, issues};
}

function cid(url) {
  let h = 0;
  for (const c of url) h = Math.imul(31, h) + c.charCodeAt(0) | 0;
  return 'c' + Math.abs(h);
}

function switchTab(id, idx) {
  const card = document.getElementById(id);
  card.querySelectorAll('.tab').forEach((t, i) => t.classList.toggle('active', i === idx));
  card.querySelectorAll('.tab-pane').forEach((p, i) => p.classList.toggle('active', i === idx));
}

function renderCard(url, analysis, platform) {
  const id = cid(url);
  const platInfo = platform ? PLATFORMS[platform] : null;
  const bc = analysis.status === 'ok' ? 'badge-ok' : analysis.status === 'ng' ? 'badge-ng' : 'badge-warn';
  const bl = analysis.status === 'ok' ? 'OK — 正常' : analysis.status === 'ng' ? 'NG — 未挿入' : 'WARN — 要確認';
  const issuesHtml = analysis.issues.map(i => `<li>${i}</li>`).join('');
  const platHtml = platInfo
    ? `<div class="plat"><i class="fa-solid fa-laptop"></i>&nbsp;${platInfo.name}&nbsp;·&nbsp;<a href="${platInfo.guide}" target="_blank">タグ設置ガイド <i class="fa-solid fa-arrow-up-right-from-square" style="font-size:10px"></i></a></div>`
    : '';
  const ssId = id + '_ss';

  const cardHtml = `<div class="result-card" id="${id}">
    <div class="rh">
      <span class="badge ${bc}">${bl}</span>
      <div class="rurl"><a href="${url}" target="_blank">${url}</a></div>
    </div>
    <div class="rb">
      <div class="tabs">
        <button class="tab active" onclick="switchTab('${id}',0)"><i class="fa-solid fa-list-check"></i>&nbsp;診断結果</button>
        <button class="tab" onclick="switchTab('${id}',1)"><i class="fa-solid fa-camera"></i>&nbsp;海外IPプレビュー</button>
      </div>
      <div class="tab-pane active" id="${id}_p0">
        <ul class="issue-list">${issuesHtml}</ul>
        ${platHtml}
      </div>
      <div class="tab-pane" id="${id}_p1">
        <div class="ss-wrap" id="${ssId}"><i class="fa-solid fa-spinner fa-spin"></i>&nbsp;読み込み中...</div>
        <p class="ss-note">
          <i class="fa-solid fa-circle-info" style="color:var(--info-text);margin-right:4px"></i>確認まで数秒かかる場合があります。しばらくお待ちください。<br>
          米国サーバー経由でのレンダリング表示です。ZenLinkのポップアップ除外設定を行っている場合や、特定条件下では表示されないことがあります。<br>
          実際のブラウザでの確認は <a href="https://www.browserling.com" target="_blank">Browserling</a> もご利用ください。
        </p>
      </div>
    </div>
  </div>`;

  const existing = document.getElementById(id);
  if (existing) existing.outerHTML = cardHtml;
  else document.getElementById('results').insertAdjacentHTML('afterbegin', cardHtml);

  // スクリーンショット読み込み
  const wrap = document.getElementById(ssId);
  const img = new Image();
  img.onload = () => {
    wrap.innerHTML = '';
    wrap.style.minHeight = '';
    img.style.cssText = 'width:100%;display:block';
    wrap.appendChild(img);
    const badge = document.createElement('div');
    badge.className = 'ss-badge';
    badge.textContent = '米国サーバー経由';
    wrap.appendChild(badge);
  };
  img.onerror = () => {
    wrap.innerHTML = '<span style="color:var(--warn-text);font-size:12px"><i class="fa-solid fa-triangle-exclamation"></i>&nbsp;スクリーンショットの取得に失敗しました</span>';
  };
  img.src = `https://shot.screenshotapi.net/screenshot?token=${SS_TOKEN}&url=${encodeURIComponent(url)}&output=image&width=1280&height=800&delay=1000`;
}

async function runCheck() {
  const input = document.getElementById('urlInput');
  let url = input.value.trim();
  if (!url) return;
  if (!/^https?:\/\//i.test(url)) url = 'https://' + url;

  const btn = document.getElementById('checkBtn');
  btn.disabled = true;
  btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> 確認中...';

  const id = cid(url);
  const results = document.getElementById('results');

  const placeholder = `<div class="result-card" id="${id}">
    <div class="rh">
      <span class="badge badge-loading"><i class="fa-solid fa-spinner fa-spin"></i>&nbsp;解析中...</span>
      <div class="rurl"><a href="${url}" target="_blank">${url}</a></div>
    </div>
  </div>`;
  const existing = document.getElementById(id);
  if (existing) existing.outerHTML = placeholder;
  else results.insertAdjacentHTML('afterbegin', placeholder);

  try {
    const html = await fetchHtml(url);
    const analysis = analyzeTag(html);
    const platform = detectPlatform(html);
    renderCard(url, analysis, platform);
  } catch(e) {
    const el = document.getElementById(id);
    if (el) el.outerHTML = `<div class="result-card" id="${id}">
      <div class="rh">
        <span class="badge badge-ng">エラー</span>
        <div class="rurl"><a href="${url}" target="_blank">${url}</a></div>
      </div>
      <div class="rb"><ul class="issue-list"><li>${e.message || 'ページの取得に失敗しました。URLを確認してください。'}</li></ul></div>
    </div>`;
  }

  btn.disabled = false;
  btn.innerHTML = '<i class="fa-solid fa-magnifying-glass"></i> 確認する';
}

document.getElementById('urlInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') runCheck();
});
</script>
</body>
</html>
